pipeline {
    agent {
  label 'Server1'
        }
    parameters {
  choice choices: ['dev', 'prod'], name: 'select_environment'
}
    environment {
        NAME = "Navya"
    }
    tools {
  maven 'mymaven'
        }
    stages {
        stage('Build') {
            steps {
                sh 'mvn clean package'
                echo "hello $NAME ${params.LASTNAME}"
            }
        }
    stage ('test') {
        parallel {
            stage('testA') {
                steps{
                echo " This is a testA"
                }
            }
            
            stage('testB') {
                steps{
                echo " This is a testB"
                }
            }
        }
        post {
            success {
                    dir("webapp/target/")
                    {
                        stash name: "maven-build", includes: "*.war"
                    }
                }
            }
    }
    stage ("deploy-_dev")
    {
        when { 
            beforeAgent true
            expression {params.select_environment == "dev"}
        }
        agent { label "devServer"}
        steps
        {
            dir("/var/www/html")
            {
                unstash "maven-build"
            }
            sh """
            cd /var/www/html/
            jar -xvf webapp.war
            """
        }
    }
    }
}


