pipeline {
    agent {
  label 'Server1'
        }
    parameters {
  string defaultValue: 'M', name: 'LASTNAME'
}
    environment {
        NAME = "Navya"
    }
    tools {
  maven 'mymaven'
        }
    stages {
        stage('Build') {
            steps {
                sh 'mvn clean package'
                echo "hello $NAME ${params.LASTNAME}"
            }
            post {
                success {
                    archiveArtifacts artifacts: '**/target/*.war'
                }
            }
        }
    }
}


