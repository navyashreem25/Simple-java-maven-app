pipeline {
    agent any
    tools {
        maven 'Maven'
    }
    parameters {
        string(name: 'VERSION', defaultValue: '', description: 'version to deploy on prod')
        choice(name: 'VERSION', choices: ['1.1.0', '1,2,0', '1,3,0'], description: '')
        booleanParam(name: 'executeTests', defaultValue: true, discription: '')

    }
    environment {
        NEW_VERSION = '1.3.0'
        //SERVER_CREDENTIALS = credentials('server-credentials')
}

    stages {
        stage('Build') {
            steps {
                echo 'Building the application...'
                echo "Building the version ${NEW_VERSION}"
            }
            stage('Test') {
                steps {
                    echo 'Testing the application...'
                    when {
                        expression {
                            params.executeTests == true
                        }
                    }
                }
            }
            stage('Deploy') {
                //echo "Deploying with ${SERVER_CREDENTIALS}"

                //Wrapper syntax : if  we want to use the credentials only in one stage then don't use credentials in environment
                withCredentials([
                    usernamePassword(credentials: 'server-credentials', usernameVariable: USER, passwordVariable: PWD)
                ]) {
                    sh "some script ${USER} ${PWD}"

                }
                steps {
                    echo "Deploying the application..."
                    echo "deploying the version ${params.VERSION}"
                }
            }

            }
        }
    }
}


